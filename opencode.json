{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "obsidian": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-obsidian"
      ],
      "enabled": true,
      "env": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}",
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      }
    }
  },
  "agent": {
    "web-search": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "web-search-modules/academic-papers": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "web-search-modules/chinese-tech": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "web-search-modules/general-web": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "web-search-modules/github-debug": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "web-search-modules/stackoverflow": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  }
}
